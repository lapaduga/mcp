PORT=3000
LOG_LEVEL=info

# Внешние MCP-серверы (опционально)
# Отключить внешние серверы: MCP_EXTERNAL_ENABLED=false
MCP_EXTERNAL_ENABLED=true

# Формат для одного сервера (legacy):
# MCP_EXTERNAL_ID=everything
# MCP_EXTERNAL_COMMAND=npx
# MCP_EXTERNAL_ARGS=-y,@modelcontextprotocol/server-everything

# Формат для нескольких серверов (через ;):
# MCP_EXTERNAL_SERVERS=everything,npx,-y,@modelcontextprotocol/server-everything;weather,npx,-y,@modelcontextprotocol/server-weather

# Чат с LLM (MCP-агент)
CHAT_API_KEY=sk-or-v1-...
# CHAT_MODEL=deepseek-chat
# CHAT_BASE_URL=https://api.deepseek.com
